# Flask session secret. If unset, a dev key is auto-generated and persisted
# to instance/secret_key -- set this explicitly for any real deployment.
SECRET_KEY=

# Flask dev server binding. Keep debug=false and host=127.0.0.1 unless you
# are running locally and need the interactive debugger / LAN access.
FLASK_DEBUG=false
FLASK_HOST=127.0.0.1

# OpenAI API key for AI task extraction. Falls back to keyword-based
# extraction if unset.
OPENAI_API_KEY=

# Recipient address for scheduler email reminders.
NOTIFICATION_EMAIL=

# Enable the background scheduler (auto-archive, stale-task reminders).
SCHEDULER_ENABLED=true

# Gmail SMTP credentials used by modules/emailer.py to send reminder emails.
GMAIL_ADDRESS=
GMAIL_PASSWORD=
